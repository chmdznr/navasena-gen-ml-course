          "output_type": "stream",
          "name": "stdout",
          "text": [
            "Hai teman‑teman bootcamp, selamat datang dan semoga belajarannya menyenangkan!\n",
            "Rail aktif: ['generate user intent (passed)', 'toxicity check (passed)']\n"
          ]
        }
      ]
